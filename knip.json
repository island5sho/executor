{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "exclude": [
    "duplicates"
  ],
  "ignoreDependencies": [
    "react-grab"
  ],
  "ignoreIssues": {
    "packages/kernel/runtime-deno-subprocess/src/deno-subprocess-worker.mjs": [
      "files"
    ]
  },
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "apps/*": {
      "entry": [
        "src/index.ts",
        "src/main.ts",
        "src/server.ts",
        "src/cli/main.ts"
      ],
      "project": [
        "src/**/*.{js,mjs,cjs,jsx,ts,tsx,mts,cts}"
      ]
    },
    "apps/web": {
      "entry": [
        "src/index.html",
        "src/frontend.tsx",
        "src/dev.ts",
        "src/server.ts"
      ],
      "project": [
        "src/**/*.{js,mjs,cjs,jsx,ts,tsx,mts,cts,css,html}"
      ]
    },
    "examples/*": {
      "entry": [
        "src/index.ts",
        "src/main.ts",
        "src/server.ts",
        "src/smoke.ts"
      ],
      "project": [
        "src/**/*.{js,mjs,cjs,jsx,ts,tsx,mts,cts}"
      ]
    },
    "packages/*/*": {
      "entry": [
        "src/index.ts",
        "src/main.ts",
        "src/playground.ts"
      ],
      "project": [
        "src/**/*.{js,mjs,cjs,jsx,ts,tsx,mts,cts}"
      ]
    }
  }
}
